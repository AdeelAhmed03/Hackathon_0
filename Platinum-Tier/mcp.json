{
  "mcpServers": {
    "email": {
      "command": "node",
      "args": ["mcp-servers/email-mcp/index.js"],
      "env": {
        "MCP_EMAIL_SERVER": "${MCP_EMAIL_SERVER}",
        "MCP_EMAIL_PORT": "${MCP_EMAIL_PORT}",
        "MCP_EMAIL_ADDRESS": "${MCP_EMAIL_ADDRESS}",
        "MCP_EMAIL_APP_PASSWORD": "${MCP_EMAIL_APP_PASSWORD}",
        "MCP_EMAIL_DRY_RUN": "${MCP_EMAIL_DRY_RUN}"
      }
    },
    "odoo": {
      "command": "python",
      "args": ["mcp-servers/odoo-mcp/odoo_mcp.py"],
      "env": {
        "ODOO_URL": "${ODOO_URL}",
        "ODOO_DB": "${ODOO_DB}",
        "ODOO_USERNAME": "${ODOO_USERNAME}",
        "ODOO_PASSWORD": "${ODOO_PASSWORD}",
        "ODOO_DRY_RUN": "${ODOO_DRY_RUN}"
      }
    },
    "social": {
      "command": "python",
      "args": ["mcp-servers/social-mcp/social_mcp.py"],
      "env": {
        "FB_PAGE_ID": "${FB_PAGE_ID}",
        "FB_ACCESS_TOKEN": "${FB_ACCESS_TOKEN}",
        "FB_DRY_RUN": "${FB_DRY_RUN}",
        "IG_BUSINESS_ACCOUNT_ID": "${IG_BUSINESS_ACCOUNT_ID}",
        "X_API_KEY": "${X_API_KEY}",
        "X_API_SECRET": "${X_API_SECRET}",
        "X_ACCESS_TOKEN": "${X_ACCESS_TOKEN}",
        "X_ACCESS_SECRET": "${X_ACCESS_SECRET}",
        "X_BEARER_TOKEN": "${X_BEARER_TOKEN}",
        "X_DRY_RUN": "${X_DRY_RUN}"
      }
    },
    "social-fb": {
      "command": "node",
      "args": ["mcp-servers/social-mcp-fb/social-mcp-fb.js"],
      "env": {
        "FB_PAGE_ID": "${FB_PAGE_ID}",
        "FB_ACCESS_TOKEN": "${FB_ACCESS_TOKEN}",
        "FB_DRY_RUN": "${FB_DRY_RUN}"
      }
    },
    "social-ig": {
      "command": "node",
      "args": ["mcp-servers/social-mcp-ig/social-mcp-ig.js"],
      "env": {
        "IG_BUSINESS_ACCOUNT_ID": "${IG_BUSINESS_ACCOUNT_ID}",
        "FB_ACCESS_TOKEN": "${FB_ACCESS_TOKEN}",
        "IG_DRY_RUN": "${IG_DRY_RUN}"
      }
    },
    "social-x": {
      "command": "node",
      "args": ["mcp-servers/social-mcp-x/social-mcp-x.js"],
      "env": {
        "X_API_KEY": "${X_API_KEY}",
        "X_API_SECRET": "${X_API_SECRET}",
        "X_ACCESS_TOKEN": "${X_ACCESS_TOKEN}",
        "X_ACCESS_SECRET": "${X_ACCESS_SECRET}",
        "X_BEARER_TOKEN": "${X_BEARER_TOKEN}",
        "X_DRY_RUN": "${X_DRY_RUN}"
      }
    }
  }
}
